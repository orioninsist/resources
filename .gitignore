# Varsayilan: hicbir dosyayi takip etme.
*

# Kokte sadece repo yonetim dosyalari takip edilir.
!.gitignore
!README.md
!resources-index.md
!resources-index.sh

# Markdown kaynak klasorleri.
# Yeni bir kaynak klasoru acarsan buraya uc satir ekle:
# !/klasor-adi/
# !/klasor-adi/**/
# !/klasor-adi/**/*.md
#
# Bu listenin disindaki hicbir klasordeki .md dosyasi takip edilmez.
!/tools/
!/tools/**/
!/tools/**/*.md
!/topics/
!/topics/**/
!/topics/**/*.md

# Kok dizindeki baska Markdown dosyalari takip edilmez.
/*.md
!/README.md
!/resources-index.md
